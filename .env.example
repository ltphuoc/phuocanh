# Required for current runtime
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54330/postgres
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional / reserved for future trusted server tasks.
# Current app runtime does not require this.
SUPABASE_SERVICE_ROLE_KEY=

# Live gameplay prompt generation.
OPENAI_API_KEY=
# Optional override. Defaults to gpt-4o-mini in app code.
# OPENAI_DAILY_QUESTION_MODEL=
# Test-only override for browser E2E runs. When set, gameplay prompt generation
# returns this fixed question instead of calling the OpenAI Responses API.
# OPENAI_DAILY_QUESTION_STUB_RESPONSE=
# Test-only auth helper for local browser E2E runs. Never enable this in hosted environments.
# E2E_ENABLE_EMAIL_OTP_HELPER=false

# Unused future integrations. Leave commented until a dedicated feature wires them.
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
