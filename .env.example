# Default local development values. Use hosted values only in Vercel/provider env vars or for an
# intentional local smoke test against the deployed Supabase project.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required only for SQL tooling such as Drizzle.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54330/postgres

# Optional app runtime secrets.
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_DAILY_QUESTION_MODEL=gpt-4o-mini

# Local/E2E only. Never enable these in hosted environments.
# OPENAI_DAILY_QUESTION_STUB_RESPONSE=your-fixed-test-question
# E2E_ENABLE_EMAIL_OTP_HELPER=false
# E2E_BASE_URL=http://127.0.0.1:3100
# E2E_RUN_TOKEN=your-test-run-token
# PLAYWRIGHT_HEADLESS=1

# Supabase Edge Function secrets for reminder-processor.
# Set these with Supabase secrets, not as browser-exposed Vercel variables.
# SUPABASE_URL=https://your-project-ref.supabase.co
# RESEND_API_KEY=your-resend-api-key
# REMINDER_FROM_EMAIL=reminders@example.com
# REMINDER_FROM_NAME=PhuocAnh
# REMINDER_APP_BASE_URL=https://your-production-domain.example.com
# REMINDER_LOCALE=vi

# Supabase Vault secret names used by hosted cron invocation.
# project_url=https://your-project-ref.supabase.co
# anon_key=your-supabase-anon-key
